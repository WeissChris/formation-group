# ----------------------------------------------------------------------------
# Ange Colins booking site — environment variables
# Copy this file to ".env.local" and fill in the values.
# The site runs WITHOUT any of these (it falls back to an in-memory demo store),
# but bookings will only persist when Supabase is configured.
# ----------------------------------------------------------------------------

# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service role key (server-side only — never exposed to the browser).
# Found in: Supabase Dashboard → Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# Password for the /admin dashboard where Ange reviews bookings.
# If unset, defaults to "ange-admin" (change this before going live!).
ADMIN_PASSWORD=
