{
  "kind": "sssp",
  "brand": "formation",
  "brandName": "Formation Landscapes",
  "templateVersion": "v1",
  "jurisdiction": "VIC",
  "title": "Site-Specific Safety Plan",
  "subtitle": "Domestic Landscape Construction",
  "groups": [
    {
      "id": "site-details",
      "title": "Site Details",
      "pdfSection": true,
      "fields": [
        { "key": "SITE_ADDRESS",          "label": "Site street address",        "type": "string",  "required": true },
        { "key": "SITE_SUBURB",           "label": "Suburb",                     "type": "string",  "required": true },
        { "key": "SITE_POSTCODE",         "label": "Postcode",                   "type": "string",  "required": true },
        { "key": "OWNER_NAME",            "label": "Building Owner name(s)",     "type": "string",  "required": true },
        { "key": "OWNER_PHONE",           "label": "Building Owner phone",       "type": "phone",   "required": true },
        { "key": "SITE_SUPERVISOR_NAME",  "label": "Formation site supervisor",  "type": "string",  "required": true },
        { "key": "SITE_SUPERVISOR_PHONE", "label": "Site supervisor phone",      "type": "phone",   "required": true },
        { "key": "PRINCIPAL_CONTRACTOR",  "label": "Principal Contractor for the construction project",
          "type": "enum", "required": true,
          "enumOptions": [
            { "value": "formation","label": "Formation Landscapes (us)" },
            { "value": "lume",     "label": "Lume Pools (concurrent project on same site)" },
            { "value": "builder",  "label": "Head builder (separate contract)" },
            { "value": "owner",    "label": "Owner-builder" }
          ],
          "helperText": "Vic OHS Regs s291 — one PC per construction project. If Lume Pools is concurrently constructing a pool on the same site, the PC for the combined works is usually whichever party holds the head contract."
        },
        { "key": "CONCURRENT_LUME_PROJECT", "label": "Concurrent Lume Pools project on this site?",
          "type": "boolean", "required": true,
          "helperText": "If yes, this SSSP must cross-reference the Lume SSSP and acknowledge concurrent works hazards (mobile plant interference, shared access, scheduling)."
        },
        { "key": "WORKSAFE_NOTIFIABLE",   "label": "Notifiable construction project under Vic OHS Act?",
          "type": "boolean", "required": true,
          "helperText": "Notifiable if project value > $350,000 OR involves high-risk construction work per Reg 5.1.5."
        }
      ]
    },
    {
      "id": "site-context",
      "title": "Site Context & Existing Conditions",
      "pdfSection": true,
      "fields": [
        { "key": "SITE_ACCESS",           "label": "Vehicle and plant access route", "type": "longtext", "required": true },
        { "key": "PUBLIC_FOOTPATH_CROSS", "label": "Will work disturb or cross a public footpath?", "type": "boolean", "required": true },
        { "key": "FOOTPATH_PROTECTION",   "label": "Footpath protection plan",   "type": "longtext", "visibility": { "field": "PUBLIC_FOOTPATH_CROSS", "equals": true } },
        { "key": "NEIGHBOUR_CONSIDERATIONS","label": "Sensitive neighbours / shared boundaries / noise", "type": "longtext" },
        { "key": "OVERHEAD_POWER",        "label": "Overhead power lines within 6.4m of plant arc?", "type": "boolean", "required": true },
        { "key": "OVERHEAD_POWER_NOTES",  "label": "Overhead power mitigation",  "type": "longtext", "visibility": { "field": "OVERHEAD_POWER", "equals": true } },
        { "key": "DBYD_DONE",             "label": "DBYD search completed?",     "type": "boolean", "required": true },
        { "key": "DBYD_REF",              "label": "DBYD reference",             "type": "string",  "visibility": { "field": "DBYD_DONE", "equals": true } },
        { "key": "UNDERGROUND_SERVICES",  "label": "Underground services in excavation envelope",
          "type": "multienum",
          "enumOptions": [
            { "value": "gas",        "label": "Gas" },
            { "value": "water",      "label": "Water main" },
            { "value": "sewer",      "label": "Sewer" },
            { "value": "stormwater", "label": "Stormwater" },
            { "value": "electrical", "label": "Electrical" },
            { "value": "irrigation", "label": "Existing irrigation" },
            { "value": "pool",       "label": "Pool plumbing / electrical (if existing pool)" },
            { "value": "telecoms",   "label": "Telecoms / NBN" },
            { "value": "none",       "label": "None within envelope" }
          ]
        },
        { "key": "ASBESTOS_LIKELY",       "label": "Existing structures likely to contain asbestos to be disturbed?", "type": "boolean", "required": true },
        { "key": "ASBESTOS_PLAN",         "label": "Asbestos handling plan",     "type": "longtext", "visibility": { "field": "ASBESTOS_LIKELY", "equals": true } },
        { "key": "TREES_PLAN",            "label": "Tree works (removal / pruning / protection) — planning permit refs",
          "type": "longtext",
          "helperText": "Significant tree removal often requires planning permission. Heritage overlays apply across much of inner-east Melbourne." },
        { "key": "ARBORIST_ENGAGED",      "label": "Arborist engaged for any tree works?", "type": "boolean" },
        { "key": "EXISTING_POOL",         "label": "Existing pool on site (drowning risk)?", "type": "boolean", "required": true,
          "helperText": "Drowning is a leading domestic-construction site fatality risk. If yes, control measures (barriers, no-go zones) must be defined." },
        { "key": "EXISTING_POOL_CONTROL", "label": "Existing pool — control measures during construction", "type": "longtext", "visibility": { "field": "EXISTING_POOL", "equals": true }, "required": true }
      ]
    },
    {
      "id": "work-activities",
      "title": "Planned Work Activities",
      "pdfSection": true,
      "fields": [
        { "key": "ACTIVITIES",            "label": "Activities planned on this site",
          "type": "multienum", "required": true,
          "enumOptions": [
            { "value": "set_out",           "label": "Set-out and survey" },
            { "value": "demo",              "label": "Demolition / removal of existing landscape elements" },
            { "value": "tree_works",        "label": "Tree removal / pruning" },
            { "value": "earthworks",        "label": "Bulk earthworks / regrading" },
            { "value": "excavation",        "label": "Excavation (retaining wall footings, garden beds)" },
            { "value": "retaining_wall",    "label": "Retaining wall construction" },
            { "value": "paving",            "label": "Paving / pathing" },
            { "value": "concrete_pour",     "label": "Concrete pours (slabs, footings)" },
            { "value": "pergola_steel",     "label": "Pergola / structural steel install" },
            { "value": "carpentry",         "label": "Carpentry (decking, screens, gates)" },
            { "value": "stone_install",     "label": "Stone / boulder placement (mechanical lift)" },
            { "value": "irrigation",        "label": "Irrigation install" },
            { "value": "lighting_electrical","label": "Landscape lighting / electrical (licensed)" },
            { "value": "planting",          "label": "Planting" },
            { "value": "turf",              "label": "Turf laying" }
          ]
        },
        { "key": "MAX_RETAINING_HEIGHT_M","label": "Maximum retaining wall / structure height (metres)", "type": "number",
          "helperText": "If > 2m, a registered building practitioner is required for the design + fall protection becomes a high-risk control." },
        { "key": "EXCAVATION_DEPTH_M",   "label": "Maximum excavation depth (metres)", "type": "number", "required": true },
        { "key": "WORKING_AT_HEIGHT",    "label": "Working at height > 2m planned (pergolas, top of walls)?", "type": "boolean", "required": true },
        { "key": "WAH_DETAIL",           "label": "Where / what tasks",          "type": "longtext", "visibility": { "field": "WORKING_AT_HEIGHT", "equals": true } },
        { "key": "HOT_WORK_PLANNED",     "label": "Hot work (welding / cutting / grinding) planned?", "type": "boolean" },
        { "key": "MANUAL_HANDLING_HEAVY","label": "Heavy manual handling expected (large stones, sleepers, plants)?", "type": "boolean", "required": true },
        { "key": "MANUAL_HANDLING_PLAN", "label": "Manual-handling controls (mechanical lift, two-person, breaks)", "type": "longtext", "visibility": { "field": "MANUAL_HANDLING_HEAVY", "equals": true } },
        { "key": "EQUIPMENT_ONSITE",     "label": "Plant + equipment expected on site",
          "type": "multienum",
          "enumOptions": [
            { "value": "excavator_2t",  "label": "Excavator < 5t" },
            { "value": "excavator_5t",  "label": "Excavator 5–13t" },
            { "value": "skid_steer",    "label": "Skid steer / bobcat" },
            { "value": "tipper_truck",  "label": "Tipper truck" },
            { "value": "concrete_truck","label": "Concrete agitator truck / pump" },
            { "value": "crane_hiab",    "label": "Hiab / vehicle-mounted crane (for stone)" },
            { "value": "scissor_lift",  "label": "Scissor lift / EWP" },
            { "value": "compactor",     "label": "Plate compactor / rammer" },
            { "value": "wet_saw",       "label": "Wet / dry saw (stone, concrete)" },
            { "value": "chainsaw",      "label": "Chainsaw" },
            { "value": "stump_grinder", "label": "Stump grinder" },
            { "value": "generator",     "label": "Generator" },
            { "value": "welder",        "label": "Welder" },
            { "value": "grinder",       "label": "Angle grinder" }
          ]
        }
      ]
    },
    {
      "id": "subcontractors",
      "title": "Sub-contractors Engaged",
      "pdfSection": true,
      "fields": [
        { "key": "SUBBIES",               "label": "Sub-contractors engaged",
          "type": "table", "tableRows": "variable",
          "tableColumns": [
            { "key": "TRADE",        "label": "Trade",  "type": "string", "required": true },
            { "key": "COMPANY_NAME", "label": "Company","type": "string", "required": true },
            { "key": "CONTACT_NAME", "label": "Contact","type": "string" },
            { "key": "CONTACT_PHONE","label": "Phone",  "type": "phone" }
          ]
        }
      ]
    },
    {
      "id": "site-management",
      "title": "Site Management & Welfare",
      "pdfSection": true,
      "fields": [
        { "key": "SITE_HOURS",            "label": "Site hours", "type": "string",  "defaultValue": "Mon–Fri 7am–5pm, Sat 8am–3pm, no Sundays / public holidays",  "required": true },
        { "key": "SITE_FENCED",           "label": "Site secured by perimeter fencing?", "type": "boolean", "required": true },
        { "key": "FENCING_DETAIL",        "label": "Fencing / gate detail", "type": "longtext", "visibility": { "field": "SITE_FENCED", "equals": true } },
        { "key": "SIGNAGE_AT_GATE",       "label": "Signage at gate (no unauth entry, induction QR, PPE required)?", "type": "boolean", "defaultValue": true },
        { "key": "WELFARE_TOILET",        "label": "Toilet provision",
          "type": "enum",
          "enumOptions": [
            { "value": "portable", "label": "Portable toilet on site" },
            { "value": "house",    "label": "Use of dwelling toilet (with owner permission)" },
            { "value": "none",     "label": "None — needs resolution" }
          ], "required": true
        },
        { "key": "WELFARE_WATER",         "label": "Drinking water on site", "type": "boolean", "required": true },
        { "key": "FIRST_AID_KIT",         "label": "First aid kit location", "type": "string", "required": true },
        { "key": "FIRST_AID_OFFICERS",    "label": "Trained first-aiders on site (names)", "type": "longtext" },
        { "key": "FIRE_EXTINGUISHER",     "label": "Fire extinguisher location", "type": "string", "visibility": { "field": "HOT_WORK_PLANNED", "equals": true }, "required": true }
      ]
    },
    {
      "id": "emergency-plan",
      "title": "Emergency Plan",
      "pdfSection": true,
      "fields": [
        { "key": "NEAREST_HOSPITAL",      "label": "Nearest emergency hospital", "type": "string", "required": true },
        { "key": "ASSEMBLY_POINT",        "label": "Site assembly point in event of evacuation", "type": "string", "required": true },
        { "key": "EMERGENCY_CONTACT_1",   "label": "Primary on-site emergency contact", "type": "string", "required": true },
        { "key": "EMERGENCY_CONTACT_2",   "label": "Secondary emergency contact", "type": "string", "defaultValue": "Chris Weiss — 04xx xxx xxx" },
        { "key": "INCIDENT_REPORT_PROCESS","label": "Incident reporting process briefing", "type": "longtext",
          "defaultValue": "Report to site supervisor immediately. Supervisor logs incident via the Hazard Replacement app. If notifiable per s37 OHS Act: Chris notifies WorkSafe Victoria on 13 23 60 within required timeframe. Site preserved until cleared."
        }
      ]
    },
    {
      "id": "high-risk-controls",
      "title": "High-Risk Construction Work Controls",
      "pdfSection": true,
      "fields": [
        { "key": "HRCW_FALL_GT_2M",      "label": "Risk of fall > 2m — controls summary", "type": "longtext", "visibility": { "field": "WORKING_AT_HEIGHT", "equals": true }, "required": true },
        { "key": "HRCW_EXCAVATION",      "label": "Excavation > 1.5m — controls summary", "type": "longtext", "visibility": { "field": "EXCAVATION_DEPTH_M", "min": 1.5 }, "required": true },
        { "key": "HRCW_NEAR_POWER",      "label": "Work near energised electrical — controls summary", "type": "longtext", "visibility": { "field": "OVERHEAD_POWER", "equals": true }, "required": true },
        { "key": "HRCW_HOT_WORK",        "label": "Hot work — controls summary", "type": "longtext", "visibility": { "field": "HOT_WORK_PLANNED", "equals": true }, "required": true },
        { "key": "HRCW_ASBESTOS",        "label": "Asbestos — controls summary", "type": "longtext", "visibility": { "field": "ASBESTOS_LIKELY", "equals": true }, "required": true },
        { "key": "HRCW_MOBILE_PLANT",    "label": "Mobile plant operating near persons — controls summary", "type": "longtext", "required": true,
          "defaultValue": "Spotter for all excavator / skid-steer / Hiab movements within 3m of personnel. Reversing alarms operational. Exclusion zone marked. Operators hold valid HRWL where required." },
        { "key": "HRCW_CONCURRENT_LUME", "label": "Concurrent Lume Pools works — coordination controls",
          "type": "longtext", "visibility": { "field": "CONCURRENT_LUME_PROJECT", "equals": true }, "required": true,
          "defaultValue": "Lume and Formation supervisors meet at start of each day to confirm zones, plant movements, and concurrent excavation locations. Shared toolbox each Monday. Either supervisor can call a halt to shared plant operations." }
      ]
    },
    {
      "id": "review-acknowledgement",
      "title": "Review",
      "fields": [
        { "key": "DRAFTED_BY",   "label": "Drafted by", "type": "string", "required": true, "rendersInPdf": false },
        { "key": "DRAFTED_DATE", "label": "Drafted on", "type": "date",   "required": true, "rendersInPdf": false },
        { "key": "REVIEW_DATE",  "label": "Next scheduled review", "type": "date", "required": true,
          "helperText": "Default: every 90 days or sooner if site conditions or scope change materially.",
          "rendersInPdf": false }
      ]
    }
  ]
}
